const { Telegraf, Markup } = require('telegraf');
const { createClient } = require('@supabase/supabase-js');

// وضع المفاتيح والروابط مباشرة لضمان التشغيل المستقر محلياً
const SUPABASE_URL = "https://wrxwkotohlkctltbxpui.supabase.co";
const SUPABASE_ANON_KEY = "sb_publishable_PfCXKYdU6a2sNI9Jnp3rQg_zboSU_A6";
const TELEGRAM_BOT_TOKEN = "8013853608:AAHKSLk-mk1VwuvloIx8NkxlZYW36Lff1Wk";

// ربط قاعدة البيانات
const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
const bot = new Telegraf(TELEGRAM_BOT_TOKEN);

// رابط تطبيق تليجرام المصغر المستقبلي المبني على تصميم Figma
const MINI_APP_URL = "https://t.me/OBSD_mining_bot/app"; 

// أمر التشغيل الرئيسي /start
bot.start(async (ctx) => {
    const telegramId = ctx.from.id;
    const username = ctx.from.username || 'No_Username';

    try {
        // 1. التحقق من وجود المستخدم في قاعدة البيانات
        let { data: user, error } = await supabase
            .from('users')
            .select('*')
            .eq('telegram_id', telegramId)
            .single();

        // 2. إذا كان مستخدم جديد، نقوم بتسجيله فوراً
        if (!user && !error) {
            const { error: insertError } = await supabase
                .from('users')
                .insert([{ 
                    telegram_id: telegramId, 
                    x_username: username,
                    mining_status: 'NOT_STARTED',
                    referral_count: 0
                }]);
            
            if (insertError) console.error("خطأ أثناء تسجيل المستخدم الجديد:", insertError);
        }

        // 3. إرسال رسالة الترحيب مع زر فتح التطبيق المصغر (Mini App)
        ctx.reply(`أهلاً بك يا ${ctx.from.first_name} في بوت تعدين عملة OBSD! 🚀\n\nاضغط على الزر أدناه لفتح واجهة التعدين الرسمية وبدء جمع النقاط.`, 
            Markup.inlineKeyboard([
                [Markup.button.webApp('🪓 ابدأ التعدين الآن', MINI_APP_URL)]
            ])
        );

    } catch (err) {
        console.error("حدث خطأ غير متوقع:", err);
        ctx.reply("عذراً، واجهنا مشكلة في الاتصال بالخادم. يرجى المحاولة لاحقاً.");
    }
});

// تشغيل البوت
bot.launch().then(() => {
    console.log("🚀 تم تشغيل بوت OBSD بنجاح محلياً وهو جاهز لاستقبال المستخدمين!");
});

// إيقاف آمن عند إغلاق السيرفر
process.once('SIGINT', () => bot.stop('SIGINT'));
process.once('SIGTERM', () => bot.stop('SIGTERM'));